generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  // provider = "postgresql"
  // url      = env("DATABASE_URL")
  provider = "sqlite"
  url      = "file:./dev.db"
}

model tb_user {
  user_id          Int                @id @default(autoincrement())
  tel              String             @unique
  password         String             @default("123456")
  username         String             @default("")
  user_depart_role user_depart_role[]
}

model tb_depart {
  depart_id        Int                @id @default(autoincrement())
  depart           String             @default("")
  user_depart_role user_depart_role[]
  depart_role      depart_role[]
}


model tb_menu {
  menu_id   Int         @id @default(autoincrement())
  menu      String      @default("")
  role_menu role_menu[]
  add       Boolean     @default(false)
  del       Boolean     @default(false)
  update    Boolean     @default(false)
  look      Boolean     @default(false)
}


model tb_role {
  role_id          Int                @id @default(autoincrement())
  role             String             @default("")
  user_depart_role user_depart_role[]
  depart_role      depart_role[]
  role_menu        role_menu[]
}


model role_menu {
  role_menu_id Int @id @default(autoincrement())
  role_id      Int
  menu_id      Int

  role tb_role @relation(fields: [role_id], references: [role_id])
  menu tb_menu @relation(fields: [menu_id], references: [menu_id])
}

model depart_role {
  depart_role_id Int @id @default(autoincrement())
  depart_id      Int
  role_id        Int

  depart tb_depart @relation(fields: [depart_id], references: [depart_id])
  role   tb_role   @relation(fields: [role_id], references: [role_id])
}

model user_depart_role {
  user_depart_role_id Int @id @default(autoincrement())
  user_id             Int
  depart_id           Int
  role_id             Int

  user   tb_user   @relation(fields: [user_id], references: [user_id])
  depart tb_depart @relation(fields: [depart_id], references: [depart_id])
  role   tb_role   @relation(fields: [role_id], references: [role_id])
}

