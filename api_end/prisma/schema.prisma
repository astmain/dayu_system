generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  // provider = "postgresql"
  // url      = env("DATABASE_URL")
  provider = "sqlite"
  url      = "file:./dev.db"
}

model tb_user {
  id          Int     @id @default(autoincrement())
  uid         String  @unique
  username    String  @unique
  password    String
  nickname    String
  avatar      String
  email       String  @unique
  tel         String  @unique
  order       Int     @default(0)
  online      Boolean
  update_time String
  create_time String
  is_del      Boolean @default(false)
  kind        String
  role        String
  remark      String  @default("")
}

model tb_menu {
  id        Int    @id @default(autoincrement())
  menu      String @unique
  path      String @unique
  parent_id Int    @default(0)
  remark    String @default("")
}

model tb_role {
  id     Int    @id @default(autoincrement())
  role   String @unique
  remark String @default("")
}

model role_menu {
  id      Int @id @default(autoincrement())
  role_id Int
  menu_id Int

  @@unique([role_id, menu_id])
}

model role_user {
  id      Int @id @default(autoincrement())
  role_id Int
  user_id Int
}
